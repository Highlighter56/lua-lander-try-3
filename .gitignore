# =========================================================================
# Unity Official Git Ignore Rules
# =========================================================================

# Unity's autogenerated local folders (Never commit these!)
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# Memory Captures and Recordings
/[Mm]emoryCaptures/
/[Rr]ecordings/

# Crash dumps and crash reports
/CrashReports/

# WebGL build target folder
/[Bb]uild_WebGL/

# OS-specific clutter (Thumps.db, Mac DS_Store files)
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# =========================================================================
# IDE and Text Editor files (Autogenerated on your machine)
# =========================================================================

# VS Code
.vscode/
*.code-workspace

# Visual Studio cache and settings
.vs/
*.user
*.userosscache
*.sln
*.csproj
*.unityproj

# JetBrains Rider / IntelliJ
.idea/
*.sln.iml